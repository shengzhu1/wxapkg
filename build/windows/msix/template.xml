<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="wxapkg.exe"
        Arguments=""
        InstallLocation="C:\Program Files\wux1an\WeChat MiniProgram Unpacker">
    </Installer>
    <PackageInformation
        PackageName="WeChat MiniProgram Unpacker"
        PackageDisplayName="WeChat MiniProgram Unpacker"
        PublisherName="CN=wux1an"
        PublisherDisplayName="wux1an"
        Version="2.1.0.0"
        PackageDescription="A tool to unpack and analyze WeChat MiniProgram packages for educational and research purposes only.">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="com.wux1an.wxunpacker"
                Description="A tool to unpack and analyze WeChat MiniProgram packages for educational and research purposes only."
                DisplayName="WeChat MiniProgram Unpacker"
                ExecutableName="wxapkg.exe"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>WeChat MiniProgram Unpacker</DisplayName>
            <PublisherDisplayName>wux1an</PublisherDisplayName>
            <Description>A tool to unpack and analyze WeChat MiniProgram packages for educational and research purposes only.</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="wxapkg.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
